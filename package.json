{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "E-Commerce REST API",
  "main": "server.js",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/controllers",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:report": "NODE_OPTIONS=--experimental-vm-modules jest --coverage && open coverage/lcov-report/index.html",
    "dev": "nodemon server.js",
    "start": "node server.js"
  },
  "keywords": ["ecommerce", "api", "nodejs", "express", "mongodb"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "expresss": "^0.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.1",
    "nodemon": "^3.1.10",
    "server": "^1.0.42"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.1",
    "supertest": "^6.3.4"
  }
}
